# Secrets needed for local development and out-of-band generation.
# Copy this file to .env and fill in values.
# .env is gitignored and should never be committed.

# Eventbrite API personal OAuth token (required for type: eventbrite sources)
# At https://www.eventbrite.com/platform/api-keys your app lists several values
# (API key, Client secret, Public token, Private token). Use the "Private token"
# here — it's the one sent as the Bearer auth header by the Eventbrite ripper.
EVENTBRITE_TOKEN=

# Ticketmaster Discovery API key (required for type: ticketmaster sources)
# Your Ticketmaster developer app (https://developer.ticketmaster.com) issues a
# "Consumer Key" and a "Consumer Secret". Use the "Consumer Key" here — it's the
# value passed as the Discovery API `apikey` query parameter (NOT the secret).
TICKETMASTER_API_KEY=

# DICE API key (required for type: dice sources)
DICE_API_KEY=

# Browserbase API key (required for proxy: browserbase sources)
BROWSERBASE_API_KEY=

# Public, read-only third-party keys for specific sources. These are visible in
# each site's own client-side JS bundle (gated to anonymous read-only access),
# but we keep them out of source. Recover the values from the sites' bundles, or
# from this repo's pre-migration git history. Required for these sources to
# produce events; without them the source reports a clear error and zero events.
CANDLELIGHT_ALGOLIA_API_KEY=
PIONEER_SQUARE_MARKET_ANON_KEY=
BENAROYA_SITECORE_API_KEY=

# Out-of-band S3 bucket (used by generate-outofband script)
OUTOFBAND_BUCKET=calendar-ripper-outofband-220483515252

# AWS region for S3
AWS_DEFAULT_REGION=us-west-2