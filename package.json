{
  "name": "icalendar-ripper",
  "version": "1.0.0",
  "description": "A data-driven web scraping tool that generates iCalendar (.ics) files from various websites",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "postinstall": "cd web && npm ci",
    "test": "c8 vitest run",
    "test:watch": "vitest",
    "test:web": "cd web && npx vitest run",
    "test:e2e": "cd web && npx playwright test",
    "test:all": "npm run test && npm run test:web",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "generate-calendars": "tsx index.ts",
    "init-city": "tsx scripts/init-city.ts",
    "web:dev": "cd web && vite",
    "web:build": "cd web && vite build && cd .. && node scripts/inject-sw-assets.mjs",
    "web:preview": "cd web && vite preview",
    "build": "npm run generate-calendars && npm run web:build",
    "check-missing-urls": "tsx scripts/check-missing-urls.ts",
    "check-discovery-api": "tsx scripts/check-discovery-api.ts",
    "generate-outofband": "tsx scripts/generate-outofband.ts",
    "download-outofband": "tsx scripts/download-outofband.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@js-joda/core": "^5.5.3",
    "@js-joda/locale_en-us": "^4.11.0",
    "@js-joda/timezone": "^2.18.0",
    "dompurify": "^2.5.8",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.0.0",
    "html-entities": "^2.6.0",
    "ical.js": "^1.5.0",
    "ics": "^3.1.0",
    "lz-string": "^1.5.0",
    "node-html-parser": "^6.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yaml": "^2.2.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/lz-string": "^1.3.34",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "c8": "^7.14.0",
    "jsdom": "^22.1.0",
    "lz-string": "^1.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.4",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
